{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": {
	"source": "~/.config/fastfetch/wallhaven-md1rl9.png",
	"type": "kitty",
   "width": 40,
   "height": 15,
	"padding": {
	  "top": 1
	}
  },
   "display": {
        "separator": " "
   },
   
  "modules": [
	  {
		"key": "╭───────────╮",
		"type": "custom"
	  },
	  {
		"key": "│ {#31} user    {#keys}│",
		"type": "title",
		"format": "{user-name}"
	  },
	  {
		"key": "│ {#32}󰇅 hname   {#keys}│",
		"type": "title",
		"format": "{host-name}"
	  },
	  {
		"key": "│ {#93}{icon} distro  {#keys}│",
		"type": "os"
	  },
	  {
		"key": "│ {#35} kernel  {#keys}│",
		"type": "kernel"
	  },
	  {
		"key": "│ {#97}󱂬 wm      {#keys}│",
		"type": "wm"
	  },
	  {
		"key": "│ {#94} term    {#keys}│",
		"type": "terminal"
	  },
	  {
		"key": "│ {#32} shell   {#keys}│",
		"type": "shell"
	  },
     {
      "key": "│ {#93} pkgs    {#keys}│",
      "type": "packages",
      "format": "{pacman} (pacman)"
     },
     {
      "key": "│ {#33}󰍛 cpu     {#keys}│",
      "type": "cpu",
      "format": "{name}"
     },
	  {
		"key": "│ {#31}󰢮 gpu     {#keys}│",
		"type": "gpu"
	  },
	  {
		"key": "│ {#37}󰉉 disk    {#keys}│",
		"type": "disk",
		"folders": "/"
	  },
	  {
		"key": "│ {#92} memory  {#keys}│",
		"type": "memory"
	  },
     {
      "type": "command",
      "key": "│ {#91}󱦟 os age  {#keys}│",
      "text": "printf \"\\e[0m%s days\\e[0m\" \"$(( ($(date +%s) - $(stat -c %W /)) / 86400 ))\""
     },
	  {
		"key": "│ {#93}󰅐 uptime  {#keys}│",
		"type": "uptime"
	  },
	  {
		"key": "├───────────┤",
		"type": "custom"
	  },
	  {
		"key": "│ {#39} colors  {#keys}│",
		"type": "colors",
		"symbol": "circle"
	  },
	  {
		"key": "╰───────────╯",
		"type": "custom"
	  }
  ]
}
